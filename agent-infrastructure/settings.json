{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash|SendMessage",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/phase-gate.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/recall-reminder.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/sigma-retrospective.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/chain-evaluator.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/phase-gate.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "SendMessage",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/agent-calibration-tracker.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/code-debt-watcher.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/prompt-echo-detector.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/memory-sync-reminder.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/skill-evolution-tracker.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/shadow-mode.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__sigma-mem__store_agent_memory|mcp__sigma-mem__store_team_decision|mcp__sigma-mem__store_team_pattern|mcp__sigma-verify__init|mcp__sigma-verify__verify_finding|mcp__sigma-verify__cross_verify|mcp__sigma-verify__challenge",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/mcp-compliance-monitor.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__sigma-mem__recall",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/recall-reminder.py",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "effortLevel": "xhigh",
  "autoDreamEnabled": true,
  "voiceEnabled": true
}
